{
  "info": {
    "name": "Checkout API",
    "description": "Postman collection for the products and payments API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products",
            "description": "Gets all products with available stock."
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create payment (Wompi Sandbox)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"units\": 1,\n  \"cardToken\": \"tok_card_xxx\",\n  \"acceptanceToken\": \"...\",\n  \"acceptPersonalAuth\": \"...\",\n  \"installments\": 1,\n  \"customerName\": \"John Doe\",\n  \"customerEmail\": \"customer@example.com\",\n  \"deliveryAddress\": \"123 Main St\"\n}"
            },
            "url": "{{baseUrl}}/payments",
            "description": "Creates a payment with Wompi Sandbox API. Requires cardToken from the frontend."
          }
        },
        {
          "name": "Get payment by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payments/:id",
              "host": ["{{baseUrl}}"],
              "path": ["payments", ":id"],
              "variable": [{ "key": "id", "value": "" }]
            },
            "description": "Gets a payment by its UUID."
          }
        }
      ]
    }
  ]
}
